NODE_ENV=production
PORT=3000
LOG_LEVEL=info

# Model paths
MODEL_PATH=./models/model.gguf
TOPOLOGY_PATH=./models/model.ouro

# Hardware constraints
MAX_MEMORY=1073741824
THERMAL_LIMIT=medium

# Performance tuning
BUFFER_SIZE=1048576
ENABLE_CACHE=true

# WebServer
CORS_ORIGIN=*
REQUEST_TIMEOUT=300000
