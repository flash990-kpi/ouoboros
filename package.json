{
  "name": "ouroboros-asts",
  "version": "1.0.0",
  "description": "A.S.T.S. (Adaptive Sparse Topology Synthesis) - Production-ready LLM inference engine for browsers and edge devices",
  "main": "dist/orchestrator.js",
  "types": "dist/orchestrator.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node ouroboros-core/server.ts",
    "start": "node dist/server.js",
    "watch": "tsc --watch",
    "test": "jest",
    "lint": "eslint ouroboros-core --ext .ts",
    "format": "prettier --write 'ouroboros-core/**/*.ts'",
    "prebuild": "npm run lint",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "llm",
    "inference",
    "asts",
    "sparse",
    "topology",
    "synthesis",
    "webgpu",
    "webnn",
    "edge-computing",
    "neural-network"
  ],
  "author": "Arun Maso <quantalyarchitect@gmail.com>",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "events": "^3.3.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/node": "^20.3.1",
    "@types/jest": "^29.5.2",
    "typescript": "^5.1.3",
    "ts-node": "^10.9.1",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "eslint": "^8.42.0",
    "@typescript-eslint/eslint-plugin": "^5.59.9",
    "@typescript-eslint/parser": "^5.59.9",
    "prettier": "^2.8.8"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
