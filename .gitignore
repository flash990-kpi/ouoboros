*.tgz
package/
lib/huggingface.js/
public/lib/

# File di compilazione TypeScript (opzionale – se vuoi escluderli)
# *.js
# *.js.map
# *.d.ts

# Altri temporanei
*.tsbuildinfo
main.json
manifest.js
istruzioni-gemini.txt