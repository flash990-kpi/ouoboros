{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "node10",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": ".",
    "rootDir": ".",
    "allowJs": false,
    "resolveJsonModule": true,
    "noEmitOnError": false,
    "removeComments": false,
    "sourceMap": false,
    "lib": ["ES2020", "DOM"],
    "ignoreDeprecations": "6.0"
  },
  "include": [
    "kernel/**/*.ts",
    "hw/**/*.ts",
    "io/**/*.ts",
    "asts/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "**/*.js",
    "**/*.d.ts",
    "dist",
    "models",
    "public"
  ]
}